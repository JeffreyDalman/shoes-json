<!DOCTYPE html>
<html lang="nl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pas <%= shoe.modelName %> aan</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <%- include('partials/nav') %>

    <div class="container">
        <div class="card shadow-sm p-4 bg-white max-width-md mx-auto" style="max-width: 600px;">
            <h2 class="mb-4">Schoen Aanpassen</h2>
            
            <form method="POST" action="/shoe/<%= shoe.id %>/edit">
                
                <div class="mb-3">
                    <label for="modelName" class="form-label">Model Naam</label>
                    <input type="text" class="form-control" id="modelName" name="modelName" value="<%= shoe.modelName %>" required>
                </div>

                <div class="mb-3">
                    <label for="price" class="form-label">Prijs (€)</label>
                    <input type="number" step="0.01" class="form-control" id="price" name="price" value="<%= shoe.price %>" required>
                </div>

                <div class="mb-3">
                    <label for="category" class="form-label">Categorie</label>
                    <select class="form-select" id="category" name="category">
                        <option value="Lifestyle" <%= shoe.category === 'Lifestyle' ? 'selected' : '' %>>Lifestyle</option>
                        <option value="Running" <%= shoe.category === 'Running' ? 'selected' : '' %>>Running</option>
                        <option value="Basketball" <%= shoe.category === 'Basketball' ? 'selected' : '' %>>Basketball</option>
                    </select>
                </div>

                <div class="mb-3">
                    <label for="inStock" class="form-label">Voorraad Status</label>
                    <select class="form-select" id="inStock" name="inStock">
                        <option value="true" <%= shoe.inStock ? 'selected' : '' %>>In Voorraad (Beschikbaar)</option>
                        <option value="false" <%= !shoe.inStock ? 'selected' : '' %>>Uitverkocht</option>
                    </select>
                </div>

                <div class="mb-3">
                    <label for="description" class="form-label">Beschrijving</label>
                    <textarea class="form-control" id="description" name="description" rows="4" required><%= shoe.description %></textarea>
                </div>

                <div class="d-flex justify-content-between mt-4">
                    <a href="/shoe/<%= shoe.id %>" class="btn btn-secondary">Annuleren</a>
                    <button type="submit" class="btn btn-success">Opslaan in Database</button>
                </div>
            </form>
        </div>
    </div>
</body>
</html>