<!DOCTYPE html>
<html lang="nl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= brand.name %> Details</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <%- include('partials/nav') %>

    <div class="container">
        <div class="card p-4 shadow-sm mb-4">
            <h2><%= brand.name %> Details</h2>
            <p><strong>Land van herkomst:</strong> <%= brand.originCountry %></p>
            <p><strong>Hoofdkantoor:</strong> <%= brand.headquarters %></p>
            <p><strong>Opgericht in:</strong> <%= brand.foundedYear %></p>
            <p><strong>Segment:</strong> <%= brand.isHighEnd ? ' Premium / High-End' : 'Standaard' %></p>
        </div>

        <h3 class="mb-3">Schoenen van <%= brand.name %> (Subobjecten)</h3>
        <div class="row row-cols-1 row-cols-md-3 g-4">
            <% subShoes.forEach(shoe => { %>
                <div class="col">
                    <div class="card h-100 shadow-sm">
                        <div class="card-body">
                            <h5 class="card-title"><%= shoe.modelName %></h5>
                            <p class="card-text text-muted">Categorie: <%= shoe.category %></p>
                            <p class="card-text"><strong>Prijs:</strong> €<%= shoe.price.toFixed(2) %></p>
                            <a href="/shoe/<%= shoe.id %>" class="btn btn-sm btn-outline-secondary">Bekijk Product</a>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>
    </div>
</body>
</html>