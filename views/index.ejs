<!DOCTYPE html>
<html lang="nl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Schoenen Overzicht</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">

    <%- include('partials/nav') %>

    <div class="container">
        <h1 class="mb-4">Schoenen Overzicht</h1>

        <form method="GET" action="/" class="row g-3 mb-4">
            <div class="col-md-8">
                <input type="text" name="search" class="form-control" placeholder="Filter op schoennaam..." value="<%= search %>">
            </div>
            <div class="col-md-4">
                <button type="submit" class="btn btn-primary w-100">Filteren</button>
            </div>
        </form>

        <div class="table-responsive bg-white p-3 rounded shadow-sm">
            <table class="table table-striped table-hover align-middle">
                <thead>
                    <% 
                        // functie om de sorteer-URL te genereren
                        function getSortUrl(field) {
                            const order = (currentSort === field && currentOrder === 'asc') ? 'desc' : 'asc';
                            return `/?search=${search}&sort=${field}&order=${order}`;
                        }
                    %>
                    <tr>
                        <th><a href="<%= getSortUrl('id') %>">ID <%= currentSort === 'id' ? (currentOrder === 'asc' ? '^' : 'v') : '' %></a></th>
                        <th><a href="<%= getSortUrl('modelName') %>">Model <%= currentSort === 'modelName' ? (currentOrder === 'asc' ? '^' : 'v') : '' %></a></th>
                        <th><a href="<%= getSortUrl('price') %>">Prijs <%= currentSort === 'price' ? (currentOrder === 'asc' ? '^' : 'v') : '' %></a></th>
                        <th><a href="<%= getSortUrl('inStock') %>">Status <%= currentSort === 'inStock' ? (currentOrder === 'asc' ? '^' : 'v') : '' %></a></th>
                        <th><a href="<%= getSortUrl('category') %>">Categorie <%= currentSort === 'category' ? (currentOrder === 'asc' ? '^' : 'v') : '' %></a></th>
                        <th><a href="<%= getSortUrl('brand') %>">Merk <%= currentSort === 'brand' ? (currentOrder === 'asc' ? '^' : 'v') : '' %></a></th>
                        <th>Actie</th>
                    </tr>
                </thead>
                <tbody>
                    <% shoes.forEach(shoe => { %>
                        <tr>
                            <td><%= shoe.id %></td>
                            <td><strong><%= shoe.modelName %></strong></td>
                            <td>€<%= shoe.price.toFixed(2) %></td>
                            <td>
                                <span class="badge <%= shoe.inStock ? 'bg-success' : 'bg-danger' %>">
                                    <%= shoe.inStock ? 'In Voorraad' : 'Uitverkocht' %>
                                </span>
                            </td>
                            <td><%= shoe.category %></td>
                            <td><%= shoe.brand ? shoe.brand.name : 'Onbekend' %></td>
                            <td>
                                <a href="/shoe/<%= shoe.id %>" class="btn btn-sm btn-outline-primary">Bekijk Details</a>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>
</body>
</html>