<!DOCTYPE html>
<html lang="nl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= shoe.modelName %> - Details</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <%- include('partials/nav') %>

    <div class="container">
        <div class="card shadow-sm p-4 bg-white">
            <div class="row">
                <div class="col-md-6">
                    <img src="<%= shoe.imageUrl %>" class="img-fluid rounded shadow-sm mb-3" alt="<%= shoe.modelName %>">

                </div>
                <div class="col-md-6">
                    <h2><%= shoe.modelName %> (<%= shoe.id %>)</h2>
                    <a href="/shoe/<%= shoe.id %>/edit" class="btn btn-warning btn-sm my-2">📝 Deze schoen aanpassen</a>
                    <p class="text-muted"><%= shoe.category %> | Release: <%= shoe.releaseDate %></p>
                    <hr>
                    <p><strong>Beschrijving:</strong> <%= shoe.description %></p>
                    <p class="h4 text-primary">€<%= shoe.price.toFixed(2) %></p>
                    <p><strong>Status:</strong> <%= shoe.inStock ? '🟢 Beschikbaar' : '🔴 Uitverkocht' %></p>
                    <p><strong>Technologieën:</strong> <%= shoe.technologies.join(', ') %></p>
                    
                    <% if (brand) { %>
                        <div class="mt-4 p-3 bg-light rounded border-start border-primary border-4">
                            <h5>Gerelateerd Merk</h5>
                            <p>Deze schoen is geproduceerd door <strong><%= brand.name %></strong>.</p>
                            <a href="/brand/<%= brand.id %>" class="btn btn-sm btn-primary">Bekijk <%= brand.name %> Details</a>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>
    </div>
</body>
</html>